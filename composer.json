{
    "name": "dbravoan/dba-ddd-skeleton",
    "description": "A skeleton package for implementing DDD and Hexagonal Architecture in Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "David Bravo",
            "email": "david@davidbravo.com.es"
        }
    ],
    "keywords": [
        "laravel",
        "ddd",
        "hexagonal-architecture",
        "skeleton",
        "package"
    ],
    "homepage": "https://github.com/dbravoan/dba-ddd-skeleton",
    "support": {
        "issues": "https://github.com/dbravoan/dba-ddd-skeleton/issues",
        "source": "https://github.com/dbravoan/dba-ddd-skeleton"
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "lambdish/phunctional": "^2.1",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^10.11",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Dba\\DddSkeleton\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dba\\DddSkeleton\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyze": "vendor/bin/phpstan analyze src --level 9",
        "lint": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dba\\DddSkeleton\\DddSkeletonServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
